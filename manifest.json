{
  "manifest_version": 3,
  "name": "Sanitas — The Data Sanitizer",
  "version": "0.1.0",
  "description": "Sanitize sensitive text locally before ChatGPT, then restore placeholders locally.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Sanitas",
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content/chatgpt_adapter.js",
        "src/content/chatgpt_panel.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
